default_platform(:ios)

platform :ios do
  desc "Build GlucoDash en upload naar TestFlight"
  lane :build_upload do
    require 'base64'
    raw_key = ENV['FASTLANE_KEY'].to_s.strip
    # Auto-detecteer: geen PEM header = base64 formaat
    if raw_key.start_with?("-----BEGIN")
      key_pem = raw_key
      UI.message("Key formaat: PEM (direct)")
    else
      key_pem = Base64.decode64(raw_key)
      UI.message("Key formaat: base64 -> gedecodeerd naar PEM")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV['FASTLANE_KEY_ID'],
      issuer_id: ENV['FASTLANE_ISSUER_ID'],
      key_content: key_pem
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj"
    )

    update_app_identifier(
      xcodeproj: "ios/App/App.xcodeproj",
      plist_path: "App/Info.plist",
      app_identifier: "com.9CGZ7BWVXT.glucodash"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {}
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
